store: [
    sources: [
        increment_button: [event: [press: SOURCE]]
    ]

    counter:
        0 |> HOLD state {
            store.sources.increment_button.event.press
            |> THEN { state + 1 }
        }
]

document:
    Document/new(
        root:
            Element/button(
                element: store.sources.increment_button
                style: []
                label: store.counter |> Text/from_number()
            )
    )
